# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# Set OPTIMIZE=true to route every agent through the caching + compression
# wrapper instead of the raw SDK client. Leave unset for a raw comparison run.
OPTIMIZE=true

# Login for the web console (server.js). The page itself loads freely,
# this is only checked when someone actually tries to start a run.
APP_USERNAME=saurabh
APP_PASSWORD=change-me
